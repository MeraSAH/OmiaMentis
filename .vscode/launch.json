{
    "// .vscode/launch.json": "Configuraciones de debugging",
    "version": "0.2.0",
    "configurations": [
        {
            "name": "▶️ Ejecutar Main (Omnia Mentis)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "🐛 Debug Main (Con breakpoints)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "DEBUG": "true"
            },
            "stopOnEntry": false
        },
        {
            "name": "🔬 Debug Research Analytics",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/test_research_analytics.py",
                "-v",
                "--tb=short"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "🧠 Debug Identity System",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/core/essence/identity.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "💖 Debug Empathy System",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/core/mind/empathy.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "🧪 Ejecutar Tests Completos",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/",
                "-v",
                "--tb=short",
                "--cov=src",
                "--cov-report=html"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "🚀 API Server (FastAPI)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "src.api.main:app",
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        }
    ]
}